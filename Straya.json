{
  "version": "1.0",
  "name": "Straya 5 Tune",
  "description": "5-inch tune for 4S/6S",
  "author": "Instinct",
  "target": "*",
  "category": "PID",
  "commands": [
    "set p_pitch = 50",
    "set i_pitch = 110",
    "set d_pitch = 41",
    "set f_pitch = 75",
    "set p_roll = 47",
    "set i_roll = 105",
    "set d_roll = 39",
    "set f_roll = 70",
    "set p_yaw = 50",
    "set i_yaw = 110",
    "set d_yaw = 0",
    "set f_yaw = 75",
    "set dshot_idle_value = 700",
    "set d_max_gain = 38",
    "set d_max_advance = 22",
    "set motor_output_limit = 92",
    "set iterm_rotation = ON",
    "set iterm_relax = RP",
    "set iterm_relax_type = GYRO",
    "set iterm_relax_cutoff = 9",
    "set iterm_windup = 85",
    "set iterm_limit = 250",
    "set pidsum_limit = 500",
    "set pidsum_limit_yaw = 400",
    "set yaw_lowpass_hz = 0",
    "set throttle_boost = 0",
    "set throttle_boost_cutoff = 25",
    "set dterm_lpf1_dyn_min_hz = 100",
    "set dterm_lpf1_dyn_max_hz = 200",
    "set dterm_lpf1_dyn_expo = 5",
    "set dterm_lpf1_type = PT1",
    "set dterm_lpf1_static_hz = 0",
    "set dterm_lpf2_type = PT1",
    "set dterm_lpf2_static_hz = 0",
    "set dterm_notch_hz = 0",
    "set dterm_notch_cutoff = 0",
    "set vbat_sag_compensation = 0",
    "set pid_at_min_throttle = ON",
    "set anti_gravity_gain = 10",
    "set anti_gravity_cutoff_hz = 5",
    "set anti_gravity_p_gain = 100",
    "set acc_limit_yaw = 0",
    "set acc_limit = 0",
    "set rpm_filter_harmonics = 3",
    "set rpm_filter_weights = 100,100,100",
    "set rpm_filter_q = 500",
    "set rpm_filter_min_hz = 50",
    "set rpm_filter_fade_range_hz = 50",
    "set rpm_filter_lpf_hz = 150",
    "set deadband = 2",
    "set yaw_deadband = 5",
    "set dyn_notch_count = 2",
    "set dyn_notch_q = 250",
    "set dyn_notch_min_hz = 60",
    "set dyn_notch_max_hz = 600",
    "set gyro_lpf1_dyn_min_hz = 60",
    "set gyro_lpf1_dyn_max_hz = 400",
    "set gyro_lpf1_dyn_expo = 5",
    "set tpa_mode = PD",
    "set tpa_rate = 30",
    "set tpa_breakpoint = 1400",
    "set launch_control_gain = 40",
    "set thrust_linear = 35",
    "set transient_throttle_limit = 0",
    "set feedforward_transition = 0",
    "set feedforward_averaging = 2_POINT",
    "set feedforward_smooth_factor = 65",
    "set feedforward_jitter_factor = 20",
    "set feedforward_boost = 0",
    "set feedforward_max_rate_limit = 90",
    "save"
  ]
}
